# Root environment variables (shared tooling / scripts)
# NOTE: Next.js apps do NOT inherit .env files from the monorepo root.
# Each app needs its own .env.local inside apps/site/ and apps/ops/.

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Connection splitting — Supabase Pooler
# DATABASE_URL (transaction-mode, port 6543): runtime queries (Prisma client). Append ?pgbouncer=true&connection_limit=1
# DIRECT_URL  (session-mode,  port 5432): migrations only (prisma migrate dev/deploy)
# Get both from: Supabase Dashboard → Project Settings → Database → Connection Pooling
DATABASE_URL=postgresql://postgres.[project-ref].[region]:[password]@aws-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[project-ref].[region]:[password]@aws-[region].pooler.supabase.com:5432/postgres
