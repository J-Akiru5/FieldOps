# Root environment variables (shared tooling / scripts)
# NOTE: Next.js apps do NOT inherit .env files from the monorepo root.
# Each app needs its own .env.local inside apps/site/ and apps/ops/.

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string (Supabase → Project Settings → Database)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
